{
  "name": "browserwire",
  "version": "0.1.0",
  "description": "Stateless discovery pipeline — auto-discovered, typed browser APIs",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gearsec/browserwire.git"
  },
  "homepage": "https://github.com/gearsec/browserwire",
  "keywords": [
    "browser",
    "automation",
    "ai-agent",
    "api",
    "discovery"
  ],
  "exports": {
    ".": "./core/pipeline/index.js",
    "./recording": "./core/recording/index.js",
    "./manifest": "./core/manifest/index.js",
    "./healing": "./core/healing/index.js"
  },
  "files": [
    "core/",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "jsdom": "^25.0.1",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.25",
    "@langchain/core": "^1.1.36",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/langgraph": "^1.2.5",
    "@langchain/openai": "^1.3.1",
    "langsmith": "^0.5.11",
    "p-limit": "^7.3.0",
    "rrweb": "^2.0.0-alpha.20",
    "rrweb-snapshot": "^2.0.0-alpha.20",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "patchright": "^1.58.2"
  }
}
